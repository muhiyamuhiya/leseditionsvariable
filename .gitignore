# Environnement
.env
.env.local
.env.production

# Dépendances PHP (vendor/ est INCLUS dans le repo pour déploiement cPanel)
/composer
/composer.phar

# Logs
/logs/*.log

# Fichiers uploadés (stockage)
/storage/books/*
/storage/covers/*
/storage/uploads/*
/storage/extracts/*
/storage/users/*
/storage/editorial/uploads/*
/storage/editorial/deliveries/*
/storage/cache/*

# Garder les dossiers storage vides dans Git
!/storage/books/.gitkeep
!/storage/covers/.gitkeep
!/storage/uploads/.gitkeep
!/storage/extracts/.gitkeep
!/storage/users/.gitkeep
!/storage/editorial/uploads/.gitkeep
!/storage/editorial/deliveries/.gitkeep
!/storage/cache/.gitkeep

# macOS
.DS_Store

# Node
/node_modules/

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# Cache et fichiers temporaires
/cache/*
!/cache/.gitkeep
*.cache

# Archives de déploiement
/leseditionsvariable_deployment.zip
