###################################################
# Les éditions Variable — Configuration production
# À copier en .env sur le serveur, puis remplir les __À_REMPLIR__
###################################################

APP_NAME="Les éditions Variable"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://leseditionsvariable.com
APP_URL_PUBLIC=https://leseditionsvariable.com
APP_TIMEZONE=Africa/Kinshasa

###################################################
# Base de données (cPanel NitroHost)
# Le préfixe NEQ-prefix dépend de ton compte cPanel
###################################################
DB_HOST=localhost
DB_PORT=3306
DB_NAME=__À_REMPLIR__
DB_USER=__À_REMPLIR__
DB_PASSWORD=__À_REMPLIR__

###################################################
# Stripe — démarrer en mode TEST puis basculer en LIVE
###################################################
STRIPE_PUBLIC_KEY=__À_REMPLIR__
STRIPE_SECRET_KEY=__À_REMPLIR__
STRIPE_WEBHOOK_SECRET=__À_REMPLIR__

###################################################
# Money Fusion (Mobile Money Afrique — RDC, Sénégal, etc.)
#
# MONEYFUSION_API_URL : l'URL de paiement de TON compte marchand,
#   obtenue dans le dashboard Money Fusion (section "Mes liens
#   de paiement"). Format :
#   https://pay.moneyfusion.net/<NomMarchand>/<TokenMarchand>/pay/
#   Laisser VIDE pour désactiver Mobile Money en attendant la
#   validation du compte (les boutons "Mobile Money" affichent
#   alors "temporairement indisponible").
#
# MONEYFUSION_WEBHOOK_TOKEN : optionnel pour l'instant. Le webhook
#   est sécurisé par re-query de l'API MF dans
#   PaymentController::moneyFusionWebhook (cf. fix 21a47ea).
#   À utiliser plus tard si MF expose une signature/header.
#
# Voir DEPLOYMENT_GUIDE.md section "Activer Money Fusion" pour la
# checklist complète (URL webhook à déclarer côté MF, IP serveur à
# whitelister, test bout-en-bout).
###################################################
MONEYFUSION_API_URL=
MONEYFUSION_WEBHOOK_TOKEN=

###################################################
# CinetPay (Mobile Money + carte RDC, USD natif)
#
# Couvre OMCDUSD (Orange Money), AIRTELCDUSD (Airtel), MPESACDUSD (M-Pesa)
# et VISAMCDUSD (Visa/Master). Tranche 1-3000 USD. Pas de conversion :
# Variable affiche en USD, CinetPay débite en USD.
#
# CINETPAY_API_KEY / CINETPAY_SITE_ID / CINETPAY_SECRET_KEY :
#   Récupérés dans le dashboard CinetPay -> Intégration -> Paramètres API.
#   Le secret_key sert à valider le HMAC SHA256 du webhook.
#
# CINETPAY_API_URL : endpoint d'initialisation (POST). Valeur prod :
#   https://api-checkout.cinetpay.com/v2/payment
#
# CINETPAY_CHECK_URL : endpoint de vérification de statut (GET re-query
# avant fulfill, sécurité). Valeur prod :
#   https://api-checkout.cinetpay.com/v2/payment/check
#
# CINETPAY_MODE : PRODUCTION ou TEST.
#
# Le toggle d'activation côté admin est dans la table settings
# (cinetpay_active = '1') -> permet de désactiver sans toucher au .env.
###################################################
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_API_URL=https://api-checkout.cinetpay.com/v2/payment
CINETPAY_CHECK_URL=https://api-checkout.cinetpay.com/v2/payment/check
CINETPAY_MODE=PRODUCTION

###################################################
# Resend (envoi d'emails transactionnels en prod)
# Domaine d'envoi à vérifier dans Resend dashboard
###################################################
RESEND_API_KEY=__À_REMPLIR__
MAIL_FROM_EMAIL=contact@leseditionsvariable.com
MAIL_FROM_NAME="Les éditions Variable"

###################################################
# Sessions et CSRF
###################################################
SESSION_LIFETIME=43200
SESSION_SECURE=true
SESSION_HTTPONLY=true
CSRF_TOKEN_LIFETIME=7200
