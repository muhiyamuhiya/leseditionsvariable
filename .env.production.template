###################################################
# Les éditions Variable — Configuration production
# À copier en .env sur le serveur, puis remplir les __À_REMPLIR__
###################################################

APP_NAME="Les éditions Variable"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://leseditionsvariable.com
APP_URL_PUBLIC=https://leseditionsvariable.com
APP_TIMEZONE=Africa/Kinshasa

###################################################
# Base de données (cPanel NitroHost)
# Le préfixe NEQ-prefix dépend de ton compte cPanel
###################################################
DB_HOST=localhost
DB_PORT=3306
DB_NAME=__À_REMPLIR__
DB_USER=__À_REMPLIR__
DB_PASSWORD=__À_REMPLIR__

###################################################
# Stripe — démarrer en mode TEST puis basculer en LIVE
###################################################
STRIPE_PUBLIC_KEY=__À_REMPLIR__
STRIPE_SECRET_KEY=__À_REMPLIR__
STRIPE_WEBHOOK_SECRET=__À_REMPLIR__

###################################################
# Money Fusion — en attente validation
# (laisser vide pour désactiver Mobile Money temporairement)
###################################################
MONEYFUSION_API_URL=
MONEYFUSION_WEBHOOK_TOKEN=

###################################################
# Resend (envoi d'emails transactionnels en prod)
# Domaine d'envoi à vérifier dans Resend dashboard
###################################################
RESEND_API_KEY=__À_REMPLIR__
MAIL_FROM_EMAIL=contact@leseditionsvariable.com
MAIL_FROM_NAME="Les éditions Variable"

###################################################
# Sessions et CSRF
###################################################
SESSION_LIFETIME=43200
SESSION_SECURE=true
SESSION_HTTPONLY=true
CSRF_TOKEN_LIFETIME=7200
