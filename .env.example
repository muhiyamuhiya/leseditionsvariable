# ============================================
# Les éditions Variable — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Application
APP_NAME="Les éditions Variable"
APP_URL=http://localhost:8888
APP_ENV=local
APP_DEBUG=true

# Base de données (MAMP par défaut)
DB_HOST=localhost
DB_PORT=8889
DB_NAME=leseditionsvariable
DB_USER=root
DB_PASSWORD=root

# Session
SESSION_LIFETIME=7200

# Fuseau horaire
TIMEZONE=Africa/Kinshasa

# Stripe (paiement carte internationale)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Money Fusion (paiement Mobile Money Afrique)
MONEYFUSION_API_URL=
MONEYFUSION_WEBHOOK_TOKEN=

# CinetPay (Mobile Money + carte RDC, USD natif, tranche 1-3000 USD)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_API_URL=https://api-checkout.cinetpay.com/v2/payment
CINETPAY_CHECK_URL=https://api-checkout.cinetpay.com/v2/payment/check
CINETPAY_MODE=TEST

# URL publique (ngrok ou domaine prod)
APP_URL_PUBLIC=

# Codes promo
PROMO_ENABLED=true

# Email transactionnel
# Resend API utilisé quand APP_ENV=production, sinon les emails vont dans logs/mails.log.
RESEND_API_KEY=
MAIL_FROM_EMAIL=contact@leseditionsvariable.com
MAIL_FROM_NAME=Les éditions Variable
# Adresse en BCC sur tous les emails sortants (supervision admin).
# Laisse vide pour désactiver. Fallback : angellomuhiya@gmail.com
ADMIN_BCC_EMAIL=angellomuhiya@gmail.com
