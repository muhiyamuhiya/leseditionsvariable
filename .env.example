# ============================================
# Les éditions Variable — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Application
APP_NAME="Les éditions Variable"
APP_URL=http://localhost:8888
APP_ENV=local
APP_DEBUG=true

# Base de données (MAMP par défaut)
DB_HOST=localhost
DB_PORT=8889
DB_NAME=leseditionsvariable
DB_USER=root
DB_PASSWORD=root

# Session
SESSION_LIFETIME=7200

# Fuseau horaire
TIMEZONE=Africa/Kinshasa

# Stripe (paiement carte internationale)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Money Fusion (paiement Mobile Money Afrique)
MONEYFUSION_API_URL=
MONEYFUSION_WEBHOOK_TOKEN=

# URL publique (ngrok ou domaine prod)
APP_URL_PUBLIC=

# Codes promo
PROMO_ENABLED=true
